body { font-family: sans-serif; background: #f4f4f4; padding: 20px; }
h1 { text-align: center; color: #333; }
.container { display: flex; gap: 20px; justify-content: center; }
.form-box { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
input { display: block; margin-bottom: 10px; padding: 8px; width: 200px; }
button { background: #28a745; color: white; border: none; padding: 10px; cursor: pointer; width: 100%; }
